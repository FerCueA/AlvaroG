---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Terapias Naturales en Las Palmas",
  description = "Osteopatia, acupuntura y terapias naturales para tu bienestar.",
} = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
  </head>
  <body class="bg-stone-50 text-slate-800 antialiased">
    <slot />
  </body>
</html>
