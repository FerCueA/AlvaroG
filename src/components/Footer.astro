---
import { createWhatsAppLink, siteInfo } from "../data/site";

const whatsappLink = createWhatsAppLink(siteInfo.defaultWhatsappMessage);
const instagram = siteInfo.instagram;
const tiktok = siteInfo.tiktok;
---

<footer class="relative overflow-hidden px-4 pb-6 pt-4 sm:px-6">
  <div class="relative mx-auto max-w-6xl overflow-hidden soft-panel soft-blob p-5 pb-6 text-[#5a473b] sm:p-6 lg:px-8 lg:py-7">
    <div class="zen-lines absolute inset-y-0 right-0 hidden w-24 opacity-30 sm:block"></div>
    <div class="absolute right-6 top-5 hidden flex-col gap-2 sm:flex">
      <span class="pebble h-4 w-4"></span>
      <span class="pebble h-6 w-5"></span>
    </div>

    <div class="relative flex flex-col gap-5 lg:flex-row lg:items-center lg:justify-between lg:gap-8">
      <div class="max-w-2xl lg:pr-6">
        <p class="text-[0.62rem] font-semibold tracking-[0.18em] text-[#8f8173]">CONTACTO</p>
        <h2 class="font-heading mt-2 text-3xl sm:text-4xl">{siteInfo.name}</h2>
        <p class="mt-2 text-sm leading-relaxed text-[#5a473b]/75 sm:text-base">
          Osteopatía, quiromasaje y medicina china en {siteInfo.locationLong}, y también a domicilio.
        </p>
        <p class="mt-2 text-sm text-[#5a473b]/70">{siteInfo.homeServiceNote}</p>
      </div>

      <div class="flex max-w-md flex-wrap gap-2 text-sm font-semibold lg:justify-end">
        <a href={siteInfo.phoneHref} class="rounded-full bg-white px-4 py-2 transition hover:bg-[#f5f1ea]">{siteInfo.phoneDisplay}</a>
        <a href={whatsappLink} target="_blank" rel="noopener noreferrer" class="rounded-full bg-[#7d8678] px-4 py-2 text-white transition hover:bg-[#687164]">WhatsApp</a>
        <a href={instagram} target="_blank" rel="noopener noreferrer" class="rounded-full bg-white px-4 py-2 transition hover:bg-[#f5f1ea]">Instagram</a>
        <a href={tiktok} target="_blank" rel="noopener noreferrer" class="rounded-full bg-white px-4 py-2 transition hover:bg-[#f5f1ea]">TikTok</a>
      </div>
    </div>

    <div class="relative mt-3 flex flex-col gap-2 text-xs text-[#5a473b]/70 sm:flex-row sm:items-center sm:justify-between">
      <p>© 2026 Álvaro García. Todos los derechos reservados.</p>
      <a
        href="https://aleixofdezcuevas.es/"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-1.5 transition hover:text-[#5a473b]"
      >
        <span class="text-[#8f8173]">✦</span> Diseño web por aleixofdezcuevas.es
      </a>
    </div>
  </div>
</footer>
