---
import { createWhatsAppLink,  heroStats, siteInfo } from "../data/site";

const whatsappLink = createWhatsAppLink(siteInfo.defaultWhatsappMessage);
const [firstName, lastName] = siteInfo.name.split(" ");
---

<section id="inicio" class="relative overflow-hidden px-4 pb-10 pt-7 sm:px-6 sm:pb-12 sm:pt-9">
  <div class="absolute inset-0 aurora-bg opacity-80"></div>
  <div class="zen-lines absolute -right-6 top-5 h-64 w-24 rounded-[28px] opacity-45 sm:w-32"></div>
  <div class="absolute -left-8 top-8 h-32 w-32 rounded-full bg-[#e7ebec]/75 blur-3xl"></div>
  <div class="absolute bottom-0 left-1/3 h-28 w-28 rounded-full bg-[#e4dbd1]/75 blur-3xl"></div>

  <div class="absolute right-6 top-16 hidden flex-col gap-3 sm:flex">
    <span class="pebble h-12 w-9 rotate-12"></span>
    <span class="pebble h-16 w-11 -rotate-6"></span>
    <span class="pebble h-14 w-10 rotate-6"></span>
  </div>

  <div class="relative mx-auto max-w-6xl">
    <div class="grid gap-6 lg:grid-cols-[1.12fr_0.88fr] lg:items-center">
      <div class="text-[#5a473b]">
        <p class="inline-flex items-center gap-2 rounded-full leaf-chip px-3 py-1 text-[0.68rem] font-semibold tracking-[0.22em]">
          <span class="h-2 w-2 rounded-full bg-[#7d8678]"></span>
          {siteInfo.disciplines}
        </p>

        <div class="mt-3 max-w-2xl">
          <p class="font-heading text-[4.2rem] leading-[0.8] text-[#5a473b] sm:text-[5.8rem] lg:text-[7.2rem]">{firstName}</p>
          <p class="font-heading -mt-1 ml-3 text-[4.2rem] leading-[0.8] text-[#8f8173] sm:ml-8 sm:text-[5.8rem] lg:text-[7.4rem]">{lastName}</p>
          <div class="mt-3  w-24 rounded-full bg-[#b8aa9b]"></div>
        </div>

        <p class="mt-4 max-w-xl text-base leading-relaxed text-[#5a473b]/78 lg:text-lg">
          {siteInfo.heroDescription}
        </p>

        <div class="mt-5 flex flex-col gap-3 sm:flex-row">
          <a
            href={whatsappLink}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center justify-center rounded-full bg-[#7d8678] px-6 py-3 text-sm font-semibold text-white shadow-lg shadow-[#7d8678]/20 transition hover:-translate-y-0.5 hover:bg-[#687164] sm:px-8"
          >
            Reservar por WhatsApp
          </a>
          <a
            href="#servicios"
            class="inline-flex items-center justify-center rounded-full bg-white/90 px-6 py-3 text-sm font-semibold text-[#5a473b] transition hover:bg-white sm:px-8"
          >
            Ver tratamientos
          </a>
        </div>
      </div>

      <div class="relative">
        <div class="zen-lines soft-blob-alt absolute inset-2 opacity-55"></div>
        <figure class="relative soft-blob soft-panel overflow-hidden p-2">
          <img
            src="/images/hero.webp"
            alt="Terapia de bienestar"
            loading="eager"
            fetchpriority="high"
            decoding="async"
            class="soft-blob-alt h-72 w-full object-cover sm:h-84 lg:h-96"
          />
        </figure>



        <div class="mt-4 grid gap-2 sm:grid-cols-3">
          {heroStats.map((item) => (
            <div class={`rounded-[20px_14px_18px_12px] px-4 py-3 text-[#5a473b] shadow-sm ${item.tone}`}>
              <p class="font-heading text-2xl sm:text-3xl">{item.value}</p>
              <p class="mt-1 text-[0.62rem] uppercase tracking-[0.16em] opacity-75">{item.label}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>
