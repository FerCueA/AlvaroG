---
import { createWhatsAppLink, pricingPlans } from "../data/site";

type PlanView = {
  name: string;
  price: string;
  desc: string;
  tone: string;
  button: string;
  tag?: string;
  perks?: readonly string[];
};

const planStyles = [
  { tone: "bg-white/88 text-[#5a473b]", button: "bg-[#7d8678] text-white hover:bg-[#687164]" },
  { tone: "bg-[#f2ece5] text-[#5a473b]", button: "bg-[#5a473b] text-white hover:bg-[#8f8173]" },
  { tone: "bg-[#e7ebec] text-[#5a473b]", button: "bg-[#8f8173] text-white hover:bg-[#77695d]" },
  { tone: "bg-[#f5f0e9] text-[#5a473b]", button: "bg-[#5a473b] text-white hover:bg-[#8f8173]" },
] as const;

const plans: PlanView[] = pricingPlans.map((plan, index) => ({
  name: plan.name,
  price: plan.price,
  desc: plan.desc,
  tag: "tag" in plan ? plan.tag : undefined,
  perks: "perks" in plan ? plan.perks : undefined,
  ...planStyles[index],
}));
---

<section id="precios" class="relative overflow-hidden px-4 py-10 sm:px-6 sm:py-12">
  <div class="absolute inset-0 bg-[radial-gradient(circle_at_15%_20%,rgba(172,194,163,0.14),transparent_30%),radial-gradient(circle_at_85%_80%,rgba(224,214,196,0.18),transparent_32%)]"></div>
  <div class="zen-lines absolute left-0 top-8 h-40 w-24 rounded-r-3xl opacity-35"></div>

  <div class="relative mx-auto max-w-6xl">
    <div class="max-w-2xl text-[#5a473b]">
      <div class="mb-3 hidden items-center gap-2 sm:flex">
        <span class="pebble h-4 w-4"></span>
        <span class="pebble h-5 w-5"></span>
      </div>
      <p class="text-sm font-semibold tracking-[0.18em] text-[#8f8173]">PRECIOS</p>
      <h2 class="font-heading mt-2 text-3xl sm:text-4xl">Precios claros para empezar tu tratamiento con confianza.</h2>
      <p class="mt-3 text-sm leading-relaxed text-[#5a473b]/75 sm:text-base">
        Puedes reservar una sesión suelta o elegir un bono si necesitas continuidad y seguimiento.
      </p>
      <p class="mt-2 text-[0.68rem] font-medium tracking-[0.14em] text-[#8f8173] sm:hidden">DESLIZA →</p>
    </div>

    <div class="mt-7 flex snap-x snap-mandatory gap-3 overflow-x-auto pb-2 hide-scrollbar sm:grid sm:grid-cols-2 sm:gap-4 sm:overflow-visible sm:pb-0 lg:grid-cols-4">
      {plans.map((plan, index) => {
        const planLink = createWhatsAppLink(
          `Hola Álvaro, me interesa ${plan.name}. ¿Me cuentas la disponibilidad para empezar?`,
        );

        return (
          <article class={`carousel-slide-mobile relative w-[74vw] min-w-[74vw] shrink-0 snap-center px-4 py-3.5 sm:min-w-0 sm:w-full sm:max-w-none sm:p-5 shadow-[0_14px_36px_rgba(86,98,90,0.10)] ${plan.tone} ${index % 2 === 0 ? "soft-blob" : "soft-blob-alt"}`}>
            <div class="absolute right-4 top-4 hidden items-center gap-1.5 sm:flex">
              <span class="pebble h-3.5 w-3"></span>
              <span class="pebble h-4 w-3.5"></span>
            </div>

            <span class={`inline-flex rounded-full px-3 py-1 text-[0.62rem] font-semibold tracking-[0.16em] ${plan.tag ? "bg-[#8f8173] text-white" : "bg-white/75 text-current"}`}>
              {plan.tag ?? "SESIÓN / BONO"}
            </span>

            <h3 class="font-heading mt-2 text-[1.3rem] leading-tight sm:text-3xl">{plan.name}</h3>
            <p class="mt-1.5 text-[0.92rem] leading-relaxed opacity-80 sm:mt-2 sm:text-sm">{plan.desc}</p>

            {plan.perks && (
              <ul class="mt-3 space-y-1.5">
                {plan.perks.map((perk: string) => (
                  <li class="flex items-center gap-2 text-sm opacity-90">
                    <span class="flex h-4 w-4 items-center justify-center rounded-full bg-[#8f8173] text-[0.6rem] font-bold text-white">✓</span>
                    {perk}
                  </li>
                ))}
              </ul>
            )}

            <div class="mt-3 flex items-end justify-between gap-2.5">
              <div>
                <p class="text-[0.68rem] font-semibold tracking-[0.16em] opacity-65">DESDE</p>
                <p class="font-heading mt-1 text-[2rem] leading-none sm:text-5xl">{plan.price}</p>
              </div>
              <a
                href={planLink}
                target="_blank"
                rel="noopener noreferrer"
                class={`inline-flex items-center justify-center rounded-full px-3.5 py-2 text-[0.72rem] font-semibold transition sm:px-4 sm:text-sm ${plan.button}`}
              >
                Reservar
              </a>
            </div>
          </article>
        );
      })}
    </div>
  </div>
</section>
