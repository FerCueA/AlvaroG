---
import { createWhatsAppLink, siteInfo } from "../data/site";

const whatsappLink = createWhatsAppLink(siteInfo.defaultWhatsappMessage);
---

<section id="reservar" class="relative overflow-hidden px-4 py-9 sm:px-6 sm:py-10">
  <div class="absolute inset-0 bg-[radial-gradient(circle_at_20%_20%,rgba(156,166,173,0.12),transparent_28%),radial-gradient(circle_at_80%_80%,rgba(224,214,196,0.14),transparent_30%)]"></div>

  <div class="relative mx-auto max-w-5xl">
    <article class="soft-blob-alt relative bg-[#ebe4db] px-4 py-4 text-[#5a473b] shadow-[0_14px_36px_rgba(96,101,107,0.10)] sm:p-5">
      <div class="absolute right-4 top-4 hidden items-center gap-1.5 sm:flex">
        <span class="pebble h-3.5 w-3"></span>
        <span class="pebble h-4 w-3.5"></span>
      </div>

      <p class="text-[0.64rem] font-semibold tracking-[0.18em] text-[#8f8173]">RESERVAS</p>
      <h2 class="font-heading mt-1.5 text-[2rem] leading-tight sm:mt-2 sm:text-4xl">Cuéntame qué te pasa y te digo disponibilidad.</h2>
      <p class="mt-1.5 max-w-2xl text-[0.95rem] leading-relaxed text-[#5a473b]/80 sm:mt-2 sm:text-base">
        Si tienes dolor, tensión o quieres empezar un tratamiento, escríbeme por WhatsApp y te orientaré sin compromiso.
      </p>

      <div class="mt-4 flex flex-col gap-2 sm:flex-row sm:items-center sm:justify-between sm:gap-4">
        <a
          href={whatsappLink}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex w-full items-center justify-center rounded-full bg-[#7d8678] px-5 py-3 text-sm font-semibold text-white transition hover:bg-[#687164] sm:w-auto"
        >
          Reservar por WhatsApp
        </a>
        <span class="text-xs leading-relaxed text-[#5a473b]/70 sm:text-sm">{siteInfo.homeServiceNote}</span>
      </div>
    </article>
  </div>
</section>
