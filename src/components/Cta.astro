---
import { createWhatsAppLink, siteInfo } from "../data/site";

const whatsappLink = createWhatsAppLink(siteInfo.defaultWhatsappMessage);
---

<section id="reservar" class="relative overflow-hidden px-4 py-9 sm:px-6 sm:py-10">
  <div class="absolute inset-0 bg-[radial-gradient(circle_at_20%_20%,rgba(156,166,173,0.12),transparent_28%),radial-gradient(circle_at_80%_80%,rgba(224,214,196,0.14),transparent_30%)]"></div>

  <div class="relative mx-auto max-w-5xl overflow-hidden soft-blob bg-[#ebe4db] px-5 py-7 text-[#5a473b] shadow-[0_14px_36px_rgba(96,101,107,0.10)] sm:px-7 sm:py-7 lg:px-10 lg:py-9">
    <div class="zen-lines absolute inset-y-0 right-0 hidden w-20 opacity-35 sm:block"></div>
    <div class="absolute left-4 top-4 hidden items-center gap-2 sm:flex">
      <span class="pebble h-4 w-4"></span>
      <span class="pebble h-5 w-5"></span>
    </div>

    <div class="relative flex flex-col gap-5 lg:flex-row lg:items-center lg:justify-between lg:gap-8">
      <div class="max-w-2xl lg:pr-6">
        <span class="inline-flex rounded-full bg-white/82 px-4 py-1.5 text-[0.62rem] font-semibold tracking-[0.18em] text-[#8f8173]">RESERVAS</span>
        <h2 class="font-heading mt-2 text-3xl sm:text-4xl">Escríbeme y te digo disponibilidad sin compromiso.</h2>
        <p class="mt-2 text-sm leading-relaxed text-[#5a473b]/75 sm:text-base">
          Una forma sencilla de empezar tu tratamiento, con una estética más cálida, natural y relajante.
        </p>
      </div>

      <div class="flex w-full max-w-sm flex-col gap-2 sm:items-start lg:w-auto lg:max-w-[22rem] lg:items-end lg:text-right">
        <a
          href={whatsappLink}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex w-full items-center justify-center rounded-full bg-[#7d8678] px-5 py-3 text-sm font-semibold text-white transition hover:bg-[#687164] sm:w-auto"
        >
          Reservar por WhatsApp
        </a>
        <span class="text-xs leading-relaxed text-[#5a473b]/70">{siteInfo.homeServiceNote}</span>
      </div>
    </div>
  </div>
</section>
