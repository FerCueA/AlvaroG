---
const services = [
  {
    title: "Osteopatía",
    image: "/images/osteopatia.jpg",
    description: "Técnica manual para el reequilibrio corporal",
  },
  {
    title: "Acupuntura",
    image: "/images/acupuntura.jpg",
    description: "Estimulación de puntos energéticos para restaurar el flujo del cuerpo",
  },
  {
    title: "Moxibustión",
    image: "/images/moxibustion.jpg",
    description: "Terapia de calor tradicional para aliviar dolencias",
  },
  {
    title: "Vendaje Neuromuscular",
    image: "/images/vendaje.jpg",
    description: "Soporte muscular sin limitar el movimiento",
  },
  {
    title: "Auriculopuntura",
    image: "/images/auriculopuntura.jpg",
    description: "Estimulación de puntos en la oreja para tratar diferentes dolencias",
  },
];
---

<section id="servicios" class="bg-stone-50">
  <header class="mx-auto max-w-6xl px-6 pb-8 pt-14 text-center sm:pb-12 sm:pt-20" data-gsap="reveal">
    <p class="text-sm font-semibold tracking-[0.18em] text-orange-500">TRATAMIENTOS</p>
    <h2 class="font-heading mt-3 text-3xl text-slate-900 sm:text-5xl">Experiencia terapéutica por etapas</h2>
  </header>

  <!-- MÓVIL: carousel horizontal deslizable -->
  <div class="lg:hidden">
    <div class="flex items-center justify-center gap-2 px-6 pb-4 text-[0.65rem] tracking-[0.18em] text-slate-400">
      <span>DESLIZA</span>
      <span class="h-px w-10 bg-slate-300"></span>
      <span>{services.length} TRATAMIENTOS</span>
    </div>
    <div data-carousel="services" class="hide-scrollbar flex gap-4 overflow-x-auto px-6 pb-8 pt-2 [scroll-snap-type:x_mandatory] [-webkit-overflow-scrolling:touch]">
      {services.map((service, index) => {
        const whatsappMessage = encodeURIComponent(
          `Hola Álvaro, me gustaría reservar una sesión de ${service.title}. ¿Qué horario tienes disponible?`,
        );
        return (
          <article data-carousel-slide class={`carousel-slide-mobile ${index === 0 ? "is-active w-[84vw]" : "w-[78vw]"} flex-none overflow-hidden rounded-[1.6rem] border border-stone-200 bg-white shadow-lg snap-center`}>
            <div class="relative">
              <img src={service.image} alt={service.title} loading="lazy" decoding="async" class="h-52 w-full object-cover" />
              <div class="absolute inset-x-0 bottom-0 h-24 bg-linear-to-t from-slate-950/85 via-slate-950/35 to-transparent"></div>
              <div class="absolute inset-x-0 bottom-0 p-4 text-white">
                <span class="inline-block rounded-full border border-white/20 bg-white/10 px-3 py-1 text-[0.62rem] font-semibold tracking-[0.16em] text-white/90 backdrop-blur-lg">TERAPIA</span>
                <h3 class="font-heading mt-2 text-2xl leading-none">{service.title}</h3>
              </div>
            </div>
            <div class="p-5">
              <p class="text-sm leading-relaxed text-slate-500">{service.description}</p>
              <a
                href={`https://wa.me/34634810054?text=${whatsappMessage}`}
                target="_blank"
                rel="noopener noreferrer"
                class="mt-4 inline-flex items-center justify-center rounded-full bg-orange-500 px-5 py-2.5 text-xs font-semibold text-white transition hover:bg-orange-600"
              >
                Reservar sesión
              </a>
            </div>
          </article>
        );
      })}
      <div class="flex-none w-2"></div>
    </div>
    <div class="mb-10 flex items-center justify-center gap-2">
      {services.map((service, index) => (
        <button
          type="button"
          data-carousel-dot="services"
          data-index={index}
          aria-label={`Ir a ${service.title}`}
          aria-pressed={index === 0 ? "true" : "false"}
          class={`h-1.5 rounded-full transition-all duration-200 ${index === 0 ? "w-7 bg-orange-400" : "w-1.5 bg-stone-300"}`}
        ></button>
      ))}
    </div>
  </div>

  <script>
    const servicesCarousel = document.querySelector<HTMLElement>('[data-carousel="services"]');
    const servicesSlides = servicesCarousel?.querySelectorAll<HTMLElement>('[data-carousel-slide]') ?? [];
    const servicesDots = document.querySelectorAll('[data-carousel-dot="services"]');

    const setServicesActive = (activeIndex: number) => {
      servicesSlides.forEach((slide, index) => {
        slide.classList.toggle('is-active', index === activeIndex);
      });

      servicesDots.forEach((dot, index) => {
        dot.classList.toggle('w-7', index === activeIndex);
        dot.classList.toggle('bg-orange-400', index === activeIndex);
        dot.classList.toggle('w-1.5', index !== activeIndex);
        dot.classList.toggle('bg-stone-300', index !== activeIndex);
        dot.setAttribute('aria-pressed', index === activeIndex ? 'true' : 'false');
      });
    };

    const updateServicesFromScroll = () => {
      if (!servicesCarousel || servicesSlides.length === 0) return;
      const center = servicesCarousel.scrollLeft + servicesCarousel.clientWidth / 2;
      let activeIndex = 0;
      let bestDistance = Number.POSITIVE_INFINITY;

      servicesSlides.forEach((slide, index) => {
        const slideCenter = slide.offsetLeft + slide.clientWidth / 2;
        const distance = Math.abs(center - slideCenter);
        if (distance < bestDistance) {
          bestDistance = distance;
          activeIndex = index;
        }
      });

      setServicesActive(activeIndex);
    };

    servicesDots.forEach((dot) => {
      dot.addEventListener('click', () => {
        const index = Number(dot.getAttribute('data-index'));
        const target = servicesSlides[index];
        target?.scrollIntoView({ behavior: 'smooth', inline: 'center', block: 'nearest' });
      });
    });

    servicesCarousel?.addEventListener('scroll', updateServicesFromScroll, { passive: true });
    requestAnimationFrame(updateServicesFromScroll);
  </script>

  <!-- ESCRITORIO: secciones alternadas full-screen -->
  <div class="hidden lg:block">
    {services.map((service, index) => {
      const whatsappMessage = encodeURIComponent(
        `Hola Álvaro, me gustaría reservar una sesión de ${service.title}. ¿Qué horario tienes disponible?`,
      );
      const isReverse = index % 2 !== 0;
      return (
        <article class="section-screen relative overflow-hidden px-6 py-14">
          <div class="absolute inset-0 bg-linear-to-b from-stone-50 via-stone-100/40 to-stone-50"></div>
          <div
            class={`relative mx-auto grid h-full w-full max-w-6xl items-center gap-14 lg:grid-cols-2 ${
              isReverse ? "lg:[&>*:first-child]:order-2" : ""
            }`}
          >
            <figure class="overflow-hidden rounded-4xl border border-white/60 shadow-2xl shadow-stone-300/35" data-gsap="reveal">
              <img
                src={service.image}
                alt={service.title}
                loading="lazy"
                decoding="async"
                class="h-136 w-full object-cover"
                data-gsap="parallax"
              />
            </figure>
            <div class="rounded-4xl border border-white/70 bg-white/70 p-10 shadow-xl shadow-stone-300/35 backdrop-blur-xl" data-gsap="reveal" data-reveal-delay="60">
              <span class="inline-block rounded-full bg-orange-100 px-4 py-1.5 text-xs font-semibold text-orange-600 tracking-wide">Terapia</span>
              <h3 class="font-heading mt-5 text-5xl text-slate-900">{service.title}</h3>
              <p class="mt-6 max-w-lg text-lg leading-relaxed text-slate-600">{service.description}</p>
              <a
                href={`https://wa.me/34634810054?text=${whatsappMessage}`}
                target="_blank"
                rel="noopener noreferrer"
                class="mt-8 inline-flex items-center justify-center rounded-full bg-orange-500 px-7 py-3 text-base font-semibold text-white shadow-lg shadow-orange-950/20 transition duration-200 hover:bg-orange-600"
              >
                Reservar sesión
              </a>
            </div>
          </div>
        </article>
      );
    })}
  </div>
</section>
