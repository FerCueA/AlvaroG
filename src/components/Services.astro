---
import { createWhatsAppLink, services as serviceItems } from "../data/site";

const serviceStyles = [
  { tone: "bg-white/88 text-[#5a473b]", button: "bg-[#7d8678] text-white hover:bg-[#687164]" },
  { tone: "bg-[#ebe4db] text-[#5a473b]", button: "bg-[#5a473b] text-white hover:bg-[#8f8173]" },
  { tone: "bg-[#e7ebec] text-[#5a473b]", button: "bg-[#8f8173] text-white hover:bg-[#77695d]" },
  { tone: "bg-[#ede5dc] text-[#5a473b]", button: "bg-[#5a473b] text-white hover:bg-[#8f8173]" },
  { tone: "bg-white/88 text-[#5a473b]", button: "bg-[#7d8678] text-white hover:bg-[#687164]" },
] as const;

const services = serviceItems.map((service, index) => ({
  ...service,
  ...serviceStyles[index],
}));
---

<section id="servicios" class="relative overflow-hidden px-4 py-10 sm:px-6 sm:py-12">
  <div class="absolute inset-0 bg-[radial-gradient(circle_at_10%_10%,rgba(156,166,173,0.12),transparent_24%),radial-gradient(circle_at_100%_0%,rgba(233,223,209,0.16),transparent_24%)]"></div>
  <div class="zen-lines absolute right-0 top-6 h-32 w-24 rounded-l-[24px] opacity-35"></div>

  <div class="relative mx-auto max-w-6xl">
    <div class="max-w-2xl">
      <div class="mb-3 hidden items-center gap-2 sm:flex">
        <span class="pebble h-4 w-4"></span>
        <span class="pebble h-5 w-5"></span>
        <span class="pebble h-3 w-3"></span>
      </div>
      <p class="text-sm font-semibold tracking-[0.18em] text-[#8f8173]">TRATAMIENTOS</p>
      <h2 class="font-heading mt-2 text-3xl text-[#5a473b] sm:text-4xl">Inspirado en bambú, piedra y calma natural.</h2>
      <p class="mt-3 text-sm leading-relaxed text-[#5a473b]/75 sm:text-base">
        La composición busca una sensación más spa: fondos cálidos, detalles verdes y formas irregulares más creativas.
      </p>
      <p class="mt-2 text-[0.68rem] font-medium tracking-[0.14em] text-[#8f8173] sm:hidden">DESLIZA →</p>
    </div>

    <div class="mt-7 flex snap-x snap-mandatory gap-4 overflow-x-auto pb-2 hide-scrollbar sm:block sm:space-y-4 sm:overflow-visible sm:pb-0">
      {services.map((service, index) => {
        const whatsappLink = createWhatsAppLink(
          `Hola Álvaro, me gustaría reservar una sesión de ${service.title}. ¿Qué horario tienes disponible?`,
        );
        const reverse = index % 2 !== 0;

        return (
          <article class={`carousel-slide-mobile relative grid w-[76vw] min-w-[76vw] max-w-[280px] shrink-0 snap-center gap-2.5 lg:grid-cols-[0.95fr_1.05fr] lg:items-center sm:w-auto sm:min-w-0 sm:max-w-none sm:gap-3 ${reverse ? "lg:[&>*:first-child]:order-2" : ""}`}>
            <div class={`absolute top-5 -z-10 h-20 w-20 rounded-full blur-2xl ${reverse ? "right-4 bg-[#e6efe1]/70" : "left-4 bg-[#efe4d7]/70"}`}></div>

            <figure class={`relative ${reverse ? "soft-blob-alt" : "soft-blob"} zen-lines overflow-hidden bg-[#f7efe6] p-2 shadow-[0_14px_36px_rgba(86,98,90,0.10)]`}>
              <img
                src={service.image}
                alt={service.title}
                loading="lazy"
                decoding="async"
                class="relative h-32 w-full object-cover sm:h-52"
              />
            </figure>

            <div class={`${reverse ? "soft-blob" : "soft-blob-alt"} relative px-4 py-3.5 sm:p-5 shadow-[0_14px_36px_rgba(86,98,90,0.10)] ${service.tone}`}>
              <div class="absolute right-4 top-4 hidden items-center gap-1.5 sm:flex">
                <span class="pebble h-3.5 w-3"></span>
                <span class="pebble h-4 w-3.5"></span>
              </div>
              <p class="text-[0.64rem] font-semibold tracking-[0.18em] opacity-70">0{index + 1} · TRATAMIENTO</p>
              <h3 class="font-heading mt-1.5 text-[1.35rem] leading-tight sm:mt-2 sm:text-3xl">{service.title}</h3>
              <p class="mt-1.5 text-[0.92rem] leading-relaxed opacity-80 sm:mt-2 sm:text-base">{service.description}</p>
              <a
                href={whatsappLink}
                target="_blank"
                rel="noopener noreferrer"
                class={`mt-3 inline-flex items-center justify-center rounded-full px-4 py-2 text-xs font-semibold transition sm:text-sm ${service.button}`}
              >
                Reservar sesión
              </a>
            </div>
          </article>
        );
      })}
    </div>
  </div>
</section>
